{
  "schema": "waza-external-benchmark-manifest.v1",
  "name": "skill-design-review-codex-external-benchmark",
  "description": "External Waza-style benchmark for the repo-local skill-design-review-codex analyzer behavior.",
  "skill": "skill-design-review-codex",
  "runner": "scripts/run_waza_external_benchmark.js",
  "wazaEval": "benchmarks/waza/evals/skill-design-review-codex/eval.yaml",
  "resultPath": "benchmarks/waza/results/skill-design-review-codex-latest.json",
  "transcriptPath": "benchmarks/waza/transcripts/skill-design-review-codex-latest.ndjson",
  "actualUseLogPolicy": "Do not write these benchmark results to logs/skill_outcomes.jsonl.",
  "tasks": [
    {
      "id": "current-skill-design-review",
      "description": "The live repo-local skill-design-review-codex package should remain article aligned through repo-local alternative contracts.",
      "target": ".agents/skills/skill-design-review-codex",
      "expect": {
        "articleAlignmentStatus": "ARTICLE_ALIGNED",
        "articleAlignmentScore": 100,
        "mechanicalScore": 100,
        "failedGateCount": 0,
        "gateStatuses": {
          "naming_side_effect_contract": "acceptable_alt",
          "purpose_trigger_shape_role": "acceptable_alt"
        }
      }
    },
    {
      "id": "article-perfect-fixture",
      "description": "A standalone prefix-and-metadata fixture should pass the article-alignment gates without repo-local alternatives.",
      "target": "benchmarks/waza/fixtures/skill-design-review-codex/run-article-perfect",
      "expect": {
        "articleAlignmentStatus": "ARTICLE_ALIGNED",
        "articleAlignmentScore": 100,
        "mechanicalScore": 100,
        "failedGateCount": 0,
        "gateStatuses": {
          "naming_side_effect_contract": "pass",
          "purpose_trigger_shape_role": "pass"
        }
      }
    },
    {
      "id": "bad-skill-fixture",
      "description": "A vague saved-prompt fixture must not receive a perfect score.",
      "target": "benchmarks/waza/fixtures/skill-design-review-codex/bad-skill",
      "expect": {
        "articleAlignmentStatusNot": "ARTICLE_ALIGNED",
        "maxArticleAlignmentScore": 99,
        "minFailedGateCount": 1,
        "requiredIssues": [
          "article_alignment_incomplete"
        ]
      }
    },
    {
      "id": "japanese-heading-fixture",
      "description": "Japanese section headings should be detected as valid contract surfaces.",
      "target": "benchmarks/waza/fixtures/skill-design-review-codex/run-japanese-heading-perfect",
      "expect": {
        "articleAlignmentStatus": "ARTICLE_ALIGNED",
        "articleAlignmentScore": 100,
        "mechanicalScore": 100,
        "failedGateCount": 0,
        "sections": {
          "hasPurpose": true,
          "hasProcedure": true,
          "hasOutputContract": true,
          "hasEvidence": true,
          "hasVerification": true,
          "hasFailureGuard": true
        }
      }
    }
  ]
}
