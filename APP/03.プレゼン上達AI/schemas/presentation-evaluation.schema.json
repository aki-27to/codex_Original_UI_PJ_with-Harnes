{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "overallScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "readinessLabel": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "workResearch": {
      "type": "object",
      "properties": {
        "researchBasis": {
          "type": "string"
        },
        "canonicalSummary": {
          "type": "string"
        },
        "factualAnchors": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "type": "string"
          }
        },
        "presentationGap": {
          "type": "string"
        }
      },
      "required": ["researchBasis", "canonicalSummary", "factualAnchors", "presentationGap"],
      "additionalProperties": false
    },
    "presenterAnalysis": {
      "type": "object",
      "properties": {
        "rootCause": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        },
        "improvementLeverage": {
          "type": "string"
        }
      },
      "required": ["rootCause", "evidence", "improvementLeverage"],
      "additionalProperties": false
    },
    "strengths": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "detail": { "type": "string" },
          "evidence": { "type": "string" }
        },
        "required": ["title", "detail", "evidence"],
        "additionalProperties": false
      }
    },
    "blindSpots": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "detail": { "type": "string" },
          "whyItHurts": { "type": "string" },
          "fix": { "type": "string" }
        },
        "required": ["title", "detail", "whyItHurts", "fix"],
        "additionalProperties": false
      }
    },
    "actionPlan": {
      "type": "array",
      "minItems": 3,
      "maxItems": 4,
      "items": {
        "type": "object",
        "properties": {
          "step": { "type": "string" },
          "purpose": { "type": "string" },
          "drill": { "type": "string" }
        },
        "required": ["step", "purpose", "drill"],
        "additionalProperties": false
      }
    },
    "improvedOpening": {
      "type": "string"
    },
    "coachQuestions": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "string"
      }
    },
    "spokenFeedback": {
      "type": "string"
    }
  },
  "required": [
    "overallScore",
    "readinessLabel",
    "summary",
    "workResearch",
    "presenterAnalysis",
    "strengths",
    "blindSpots",
    "actionPlan",
    "improvedOpening",
    "coachQuestions",
    "spokenFeedback"
  ],
  "additionalProperties": false
}
