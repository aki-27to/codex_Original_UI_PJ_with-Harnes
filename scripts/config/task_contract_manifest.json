{
  "schema": "task-contract-manifest.v2",
  "version": "2026-03-30.r2",
  "defaultFamily": "deterministic_code",
  "contracts": [
    {
      "id": "deterministic_code",
      "familyId": "deterministic_code",
      "humanComparableTaskFraming": "Implement or fix deterministic code behavior with executable verification.",
      "successCriteria": [
        "requested behavior is implemented or the requested factual answer is produced",
        "applicable tests, probes, or executable verification pass",
        "required evidence artifacts are written before completion is claimed"
      ],
      "timeBudget": { "targetMs": 120000, "warnMs": 300000, "hardStopMs": 900000 },
      "allowedTools": ["api_exec", "batch", "shell", "apply_patch", "replay", "eval_public"],
      "deniedTools": ["request_user_input_unless_required", "external_write", "holdout_eval_lane", "blackbox_eval_lane", "destructive_delete_without_approval"],
      "stopConditions": ["requirements_satisfied", "verification_recorded", "no_unapproved_scope_expansion"],
      "approvalBoundary": { "requiredWhen": ["destructive_delete", "dependency_add", "permission_change", "external_write", "schema_migration"] },
      "difficultyTiers": ["basic", "standard", "advanced"],
      "modalityTags": ["text", "code", "filesystem"],
      "structureTags": ["deterministic", "repo_local"],
      "verifierRequirements": ["tests_or_probes", "task_outcome_contract"]
    },
    {
      "id": "coding",
