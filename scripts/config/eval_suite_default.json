{
  "schema": "harness-eval-suite.v1",
  "suiteId": "core-harness-workflow.v4",
  "description": "Regression suite covering live exec behavior plus deterministic workflow-policy probes for retired worker rejection, parent-dispatch guard enforcement, adaptive planning and assurance depth selection, task outcomes, and adversarial review.",
  "outputSchema": {
    "type": "object",
    "required": ["status", "latencyMs", "passed", "score", "reason"],
    "properties": {
      "status": { "type": "string" },
      "latencyMs": { "type": "number" },
      "passed": { "type": "boolean" },
      "score": { "type": "number" },
      "reason": { "type": "string" }
    }
  },
  "cases": [
    {
      "id": "exact_ack",
      "title": "Exact ACK contract",
      "driver": "exec",
      "prompt": "Reply with exactly: ACK",
      "weight": 1,
      "expect": { "mode": "exact", "value": "ACK" }
    },
    {
      "id": "retired_worker_rejected",
      "title": "Retired worker cannot be selected as runtime agent",
      "driver": "agent_registry_probe",
      "input": { "agentName": "worker" },
      "weight": 2,
      "expect": {
        "mode": "json_fields",
        "fields": { "ok": false, "reason": "agent_not_configured", "agentName": "worker" }
      }
    },
    {
      "id": "retired_worker_scoped_rejected",
      "title": "Retired worker scoped alias cannot be selected as runtime agent",
      "driver": "agent_registry_probe",
      "input": { "agentName": "worker@chat-legacy" },
      "weight": 1,
      "expect": {
        "mode": "json_fields",
        "fields": { "ok": false, "reason": "agent_not_configured", "agentName": "worker@chat-legacy" }
      }
    },
    {
      "id": "requirement_rbj_parent_active",
      "title": "Parent role activates requirement RBJ loop",
      "driver": "requirement_rbj_probe",
      "input": {
        "prompt": "Implement the requested backend change.",
        "options": { "agentName": "default" }
      },
      "weight": 2,
      "expect": {
        "mode": "json_fields",
        "fields": { "active": true, "mode": "requirement_definition_loop", "reason": "active" }
      }
    },
    {
      "id": "planning_mode_fast_selected",
      "title": "Small docs fix selects FAST planning and LIGHT assurance",
      "driver": "planning_mode_probe",
      "input": {
        "prompt": "# Goal\nUpdate only docs/CURRENT_ARCHITECTURE.md with one wording fix.\n# Acceptance Criteria\n- Change exactly one sentence.\n- Do not modify any other file.",
        "options": { "agentName": "default" }
      },
      "weight": 2,
      "expect": {
        "mode": "json_fields",
        "fields": {
          "selectedMode": "FAST",
          "selectedPlanningDepth": "FAST_PLANNING",
          "selectedAssuranceDepth": "LIGHT_ASSURANCE",
          "flowPath": "FAST_PATH",
          "needsInputRecommended": 0
        }
      }
    },
    {
      "id": "planning_mode_discovery_selected",
      "title": "Ambiguous task selects DISCOVERY planning and STANDARD assurance",
      "driver": "planning_mode_probe",
      "input": {
        "prompt": "# Goal\nDesign a new enterprise execution workflow for a future product line.\n# Background\nThe goal, non-goals, specialist ownership, and acceptance checks are not fixed yet.\nUser decision is required before implementation.\n# Acceptance Criteria\n- First make the open questions explicit.",
        "options": { "agentName": "default" }
      },
      "weight": 2,
      "expect": {
        "mode": "json_fields",
        "fields": {
          "selectedMode": "DISCOVERY",
          "selectedPlanningDepth": "DISCOVERY_PLANNING",
          "selectedAssuranceDepth": "STANDARD_ASSURANCE",
          "flowPath": "DISCOVERY_PATH",
          "needsInputRecommended": 1
        }
      }
    },
    {
      "id": "approval_boundary_discovery_needs_input",
      "title": "Approval-boundary task stays proposal-only and escalates assurance",
      "driver": "planning_contract_probe",
      "input": {
        "prompt": "# Goal\nPerform a dependency/runtime installation and destructive schema migration.\n# Acceptance Criteria\n- Approval boundary is crossed and user decision is required.",
        "options": { "agentName": "default" }
      },
      "weight": 2,
      "expect": {
        "mode": "json_fields",
        "fields": {
          "selectedMode": "DISCOVERY",
          "selectedPlanningDepth": "DISCOVERY_PLANNING",
          "selectedAssuranceDepth": "SIGNOFF_ASSURANCE",
          "proposalOnly": 1,
          "signoffRequired": 1
        }
      }
    },
    {
      "id": "cross_specialist_dispatch_plan",
      "title": "Cross-specialist scope produces multi-owner signoff plan",
      "driver": "planning_contract_probe",
      "input": {
        "prompt": "# Goal\nUpdate server.js and docs/CURRENT_ARCHITECTURE.md to expose the selected execution flow in runtime output.\n# Implementation Requirements\n- Update server.js runtime output.\n- Update docs/CURRENT_ARCHITECTURE.md.\n# Acceptance Criteria\n- Reviewer evidence is required.\n- Tester evidence is required.\n- Signoff evidence is required.",
        "options": { "agentName": "default" }
      },
      "weight": 2,
      "expect": {
        "mode": "json_fields",
        "fields": {
          "selectedMode": "NORMAL",
          "selectedPlanningDepth": "STANDARD_PLANNING",
          "selectedAssuranceDepth": "SIGNOFF_ASSURANCE",
          "dispatchCount": 2,
          "ownerAgents": ["backend_worker", "infra_worker"]
        }
      }
    },
    {
      "id": "reviewer_tester_required_case",
      "title": "Workflow marks reviewer tester and signoff when required",
      "driver": "planning_contract_probe",
      "input": {
        "prompt": "# Goal\nUpdate server.js and docs/CURRENT_ARCHITECTURE.md to expose the selected execution flow in runtime output.\n# Acceptance Criteria\n- Reviewer evidence is required.\n- Tester evidence is required.\n- Signoff evidence is required.",
        "options": { "agentName": "default" }
      },
      "weight": 1,
      "expect": {
        "mode": "json_fields",
        "fields": { "reviewerRequired": 1, "testerRequired": 1, "signoffRequired": 1 }
      }
    },
    {
      "id": "dedicated_test_required_for_new_logic",
      "title": "Over-delivery with new logic requires dedicated tests",
      "driver": "planning_contract_probe",
      "input": {
        "prompt": "# Goal\nRewrite the runtime protocol handling in server.js and add new logic for signoff orchestration.\n# Acceptance Criteria\n- Reviewer evidence is required.\n- Tester evidence is required.\n- Signoff evidence is required.\n- Add dedicated tests for the new logic.",
        "options": { "agentName": "default" }
      },
      "weight": 2,
      "expect": {
        "mode": "json_fields",
        "fields": { "selectedAssuranceDepth": "SIGNOFF_ASSURANCE", "testerRequired": 1, "dedicatedTestsRequired": 1 }
      }
    },
    {
      "id": "context_leakage_planning_owned_paths",
      "title": "Single-owner FAST path avoids out-of-scope owned paths",
      "driver": "planning_contract_probe",
      "input": {
        "prompt": "# Goal\nUpdate only server.js.\n# Acceptance Criteria\n- Limit owned paths to server.js.\n- Avoid context leakage.",
        "options": { "agentName": "default" }
      },
      "weight": 1,
      "expect": {
        "mode": "json_fields",
        "fields": {
          "selectedMode": "FAST",
          "selectedPlanningDepth": "FAST_PLANNING",
          "selectedAssuranceDepth": "STANDARD_ASSURANCE",
          "dispatchCount": 1,
          "ownerAgents": ["backend_worker"],
          "contextLeakageRisk": 0
        }
      }
    },
    {
      "id": "parent_dispatch_guard_violation",
      "title": "Parent completion without child dispatch is blocked",
      "driver": "parent_dispatch_guard_probe",
      "input": {
        "mode": "enforce",
        "agentName": "default",
        "executionProfile": "full-runtime",
        "finalStatus": "completed",
        "fileChanges": 1,
        "dispatchCount": 0,
        "dispatchSuccessCount": 0,
        "dispatchFailureCount": 0,
        "collabCalls": 0,
        "attempt": 0,
        "maxRetries": 1
      },
      "weight": 2,
      "expect": {
        "mode": "json_fields",
        "fields": { "violation": 1, "reason": "dispatch_not_attempted", "retry": 1 }
      }
    },
    {
      "id": "idempotency_failed_outcome_bridge",
      "title": "Idempotency duplicate bridge keeps lifecycle and failed outcome separate",
      "driver": "idempotency_bridge_probe",
      "input": {
        "state": "failed",
        "outcomeStatus": "failed",
        "taskOutcomeStatus": "FAILED_VALIDATION",
        "taskOutcomeReason": "parent_dispatch_guard_block",
        "errorText": "probe failure"
      },
      "weight": 2,
      "expect": {
        "mode": "json_fields",
        "fields": {
          "lifecycleState": "failed",
          "terminalStatus": "failed",
          "outcomeStatus": "failed",
          "duplicateOk": false,
          "internalExecStatus": "failed"
        }
      }
    },
    {
      "id": "needs_input_blocked_policy",
      "title": "Non-interactive user input can be forced to blocked",
      "driver": "request_user_input_probe",
      "input": {
        "policy": "blocked",
        "params": {
          "questions": [
            {
              "id": "approval_mode",
              "options": [
                { "label": "Safe (Recommended)", "value": "safe" },
                { "label": "Fast", "value": "fast" }
              ]
            }
          ]
        }
      },
      "weight": 1,
      "expect": {
        "mode": "json_fields",
        "fields": { "decision": "blocked", "reason": "blocked_non_interactive_user_input_policy" }
      }
    },
    {
      "id": "failed_validation_missing_evidence",
      "title": "Missing evidence maps to FAILED_VALIDATION",
      "driver": "task_outcome_probe",
      "input": { "turnStatus": "failed", "missingEvidence": true },
      "weight": 2,
      "expect": {
        "mode": "json_fields",
        "fields": { "status": "FAILED_VALIDATION", "reason": "missing_required_evidence" }
      }
    },
    {
      "id": "needs_input_from_approval",
      "title": "Approval unavailability maps to NEEDS_INPUT",
      "driver": "task_outcome_probe",
      "input": { "turnStatus": "failed", "approvalReason": "interactive_approval_unavailable" },
      "weight": 1,
      "expect": {
        "mode": "json_fields",
        "fields": { "status": "NEEDS_INPUT", "reason": "interactive_approval_unavailable" }
      }
    },
    {
      "id": "turn_task_outcome_bridge_failed_validation",
      "title": "Failed turn accepts FAILED_VALIDATION outcome",
      "driver": "turn_task_outcome_probe",
      "input": { "turnStatus": "failed", "taskOutcomeStatus": "FAILED_VALIDATION" },
      "weight": 1,
      "expect": { "mode": "json_fields", "fields": { "ok": true, "reason": "compatible" } }
    },
    {
      "id": "turn_task_outcome_bridge_blocked",
      "title": "Failed turn accepts BLOCKED outcome",
      "driver": "turn_task_outcome_probe",
      "input": { "turnStatus": "failed", "taskOutcomeStatus": "BLOCKED" },
      "weight": 1,
      "expect": { "mode": "json_fields", "fields": { "ok": true, "reason": "compatible" } }
    },
    {
      "id": "adversarial_exact_contract_mismatch",
      "title": "Adversarial shadow spots exact-contract mismatch",
      "driver": "adversarial_shadow_probe",
      "input": {
        "request": "Reply with exactly ACK",
        "assistantResponse": "ACK plus extra",
        "taskOutcomeStatus": "COMPLETED"
      },
      "weight": 1,
      "expect": {
        "mode": "json_fields",
        "fields": { "decision": "FAILED_VALIDATION", "reason": "exact_reply_contract_mismatch" }
      }
    },
    {
      "id": "adversarial_failed_validation_retry",
      "title": "Adversarial loop retries FAILED_VALIDATION once",
      "driver": "adversarial_loop_probe",
      "input": { "enabled": true, "attempt": 0, "maxRetries": 1, "decision": "FAILED_VALIDATION" },
      "weight": 1,
      "expect": {
        "mode": "json_fields",
        "fields": { "retry": true, "reason": "adversarial_failed_validation_retry" }
      }
    }
  ]
}
