      "requiredClasses": [
        "role",
        "scenario"
      ]
    },
    "backend_worker": {
      "minSkills": 4,
      "requiredClasses": [
        "global",
        "scenario"
      ]
    },
    "infra_worker": {
      "minSkills": 2,
      "requiredClasses": [
        "global",
        "role"
      ]
    },
    "tester": {
