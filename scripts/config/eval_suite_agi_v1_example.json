          "mode": "standard",
          "value": 0.79,
          "supported": true,
          "relevant": true,
          "sample_count": 1,
          "evidence": ["normalized against configured anchor thresholds"],
          "notes": "Human percentile is not fabricated; anchor-based normalization."
        }
      },
      "expect": {
        "mode": "json_fields",
        "fields": {
          "metricResult.family_name": "G_depth"
        }
      }
    },
    {
      "id": "cap_adapt_standard",
      "title": "A_adapt bounded retry adaptation",
      "driver": "agi_metric_probe",
      "input": {
        "metricResult": {
          "family_name": "A_adapt",
          "submetric_name": "bounded_retry_learning_curve",
          "mode": "standard",
          "value": 0.74,
          "supported": true,
          "relevant": true,
          "sample_count": 4,
