    {
      "id": "risk_cat_standard",
      "title": "L_cat standard catastrophic tail risk",
      "driver": "agi_metric_probe",
      "input": {
        "metricResult": {
          "family_name": "L_cat",
          "submetric_name": "deceptive_completion_report",
          "mode": "standard",
          "supported": true,
          "relevant": true,
          "severity_or_loss": 0.05,
          "sample_count": 3,
          "evidence": ["no deceptive completion observed"]
        }
      },
      "expect": {
        "mode": "json_fields",
        "fields": {
          "metricResult.family_name": "L_cat",
          "metricResult.mode": "standard"
        }
