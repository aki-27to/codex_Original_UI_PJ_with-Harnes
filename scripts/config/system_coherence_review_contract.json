      "description": "Parent/child responsibilities, evidence gates, and release posture remain internally consistent."
    },
    {
      "id": "machine_contracts",
      "description": "Machine-readable contracts, outcome taxonomy, and policy manifests remain synchronized."
    },
    {
      "id": "server_runtime",
      "description": "Server behavior, runtime evidence, and release enforcement remain aligned with the contracts."
    },
    {
      "id": "evaluation_memory",
      "description": "Eval, memory, and long-horizon lifecycle surfaces remain connected to the active execution path."
    },
    {
      "id": "artifact_surface",
      "description": "Intentional artifacts, transient runtime material, and repo-root hygiene remain taxonomy-driven."
    }
  ],
  "coreChangePathGlobs": [
