{
  "schema": "self-improvement-promotion-policy.v2",
  "mode": "machine_guarded_autonomy",
  "lifecycles": [
    "proposal_only",
    "shadow_candidate",
    "gated_candidate",
    "auto_apply_candidate",
    "blocked"
  ],
  "changeClasses": {
    "runtime_retrieval_hint": {
      "defaultLifecycle": "auto_apply_candidate",
      "blastRadius": "low"
    },
    "frontend_quality_note": {
      "defaultLifecycle": "auto_apply_candidate",
      "blastRadius": "low"
    },
    "planner_strategy": {
      "defaultLifecycle": "shadow_candidate",
      "blastRadius": "medium"
    },
    "decomposition_policy": {
      "defaultLifecycle": "shadow_candidate",
      "blastRadius": "medium"
    },
    "tool_selection_policy": {
      "defaultLifecycle": "shadow_candidate",
      "blastRadius": "medium"
    },
    "retry_recovery_policy": {
      "defaultLifecycle": "gated_candidate",
      "blastRadius": "medium"
    },
    "memory_pack_policy": {
      "defaultLifecycle": "gated_candidate",
      "blastRadius": "medium"
    },
    "skill_surface_policy": {
      "defaultLifecycle": "gated_candidate",
      "blastRadius": "medium"
    },
    "memory_policy_note": {
      "defaultLifecycle": "proposal_only",
      "blastRadius": "medium"
    },
    "eval_extension": {
      "defaultLifecycle": "proposal_only",
      "blastRadius": "medium"
    },
    "operator_policy_note": {
      "defaultLifecycle": "proposal_only",
      "blastRadius": "medium"
    },
    "runtime_policy_tuning": {
      "defaultLifecycle": "proposal_only",
      "blastRadius": "medium"
    }
  },
  "autoApply": {
    "changeClasses": [
      "runtime_retrieval_hint",
      "frontend_quality_note"
    ],
    "requireGatePass": true,
    "maxAutoApplyPerLane": 12
  },
  "shadowCandidate": {
    "changeClasses": [
      "planner_strategy",
      "decomposition_policy",
      "tool_selection_policy"
    ]
  },
  "gatedCandidate": {
    "changeClasses": [
      "retry_recovery_policy",
      "memory_pack_policy",
      "skill_surface_policy"
    ]
  },
  "targetLifecycleOverrides": {
    "scripts/config/memory_retrieval_policy.json": {
      "memory_pack_policy": "shadow_candidate"
    },
    "scripts/config/memory_type_catalog.json": {
      "memory_pack_policy": "shadow_candidate"
    },
    "docs/AGENT_SKILL_MATRIX.md": {
      "skill_surface_policy": "shadow_candidate"
    },
    "scripts/config/skill_catalog.json": {
      "skill_surface_policy": "shadow_candidate"
    }
  },
  "proposalOnly": {
    "targets": [
      "docs/AGENT_OPERATING_RULES.md",
      "docs/AGENT_SKILL_MATRIX.md",
      "docs/CONTEXT_MEMORY_POLICY.md",
      "docs/EVIDENCE_CONTRACT.md",
      "scripts/config/eval_suite_default.json",
      "scripts/config/openai_blog_learning_policy.json",
      "scripts/config/anthropic_engineering_learning_policy.json",
      "skills/web-designer-master/references/quality-gate.md",
      "server.js"
    ],
    "changeClasses": [
      "memory_policy_note",
      "eval_extension",
      "operator_policy_note",
      "runtime_policy_tuning"
    ]
  },
  "blocked": {
    "targets": [
      "AGENTS.md",
      "docs/HARNESS_CONSTITUTION.md",
      "docs/PHASE_REQUIREMENT_FOUNDATION_V1.md",
      "scripts/lib/planning_mode_policy.js",
      "scripts/config/authority_registry.json",
      "scripts/config/requirement_contract.schema.json",
      "scripts/config/dispatch_plan.schema.json",
      "scripts/lib/requirement_revision_policy.js",
      "scripts/config/iteration_control_contract.json",
      "scripts/config/task_outcome_contract.json",
      "scripts/config/evidence_contract.json",
      "scripts/config/adoption_readiness_evaluator_contract.json"
    ],
    "changeClasses": [
      "constitution",
      "authority_registry",
      "approval_boundary",
      "safety_boundary",
      "core_release_gate",
      "core_evaluator_hard_gate"
    ]
  },
  "targetedRegression": {
    "runtime_retrieval_hint": [
      "public_regression"
    ],
    "frontend_quality_note": [
      "public_regression"
    ],
    "planner_strategy": [
      "public_regression",
      "self_improvement_gate"
    ],
    "decomposition_policy": [
      "public_regression",
      "self_improvement_gate"
    ],
    "tool_selection_policy": [
      "public_regression",
      "self_improvement_gate"
    ],
    "retry_recovery_policy": [
      "public_regression",
      "self_improvement_gate"
    ],
    "memory_pack_policy": [
      "public_regression",
      "memory_eval"
    ],
    "skill_surface_policy": [
      "public_regression",
      "skill_portfolio_audit"
    ]
  },
  "evalGate": {
    "schema": "self-improvement-eval-gate.v1",
    "cases": [
      {
        "caseId": "web_creative_benchmark",
        "agentName": "default",
        "taskFamily": "web_creative",
        "prompt": "Build a benchmarked landing page in React and verify the final UI with screenshots.",
        "requiredTopics": [
          "frontend",
          "evals",
          "codex"
        ],
        "maxTopics": 6,
        "maxPromptBlockChars": 1700
      },
      {
        "caseId": "frontend_context_iteration",
        "agentName": "frontend_worker",
        "taskFamily": "web_creative",
        "prompt": "Refine the design system, manage prompt budget across revisions, and keep the UI coherent.",
        "requiredTopics": [
          "frontend",
          "context"
        ],
        "maxTopics": 6,
        "maxPromptBlockChars": 1700
      },
      {
        "caseId": "backend_non_targeted",
        "agentName": "backend_worker",
        "taskFamily": "deterministic_code",
        "prompt": "Fix the JSON parsing bug in the API route and add unit tests.",
        "forbiddenTopics": [
          "frontend",
          "skills"
        ],
        "maxTopics": 3,
        "maxPromptBlockChars": 400
      }
    ]
  }
}
