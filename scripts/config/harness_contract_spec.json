{
  "schema": "harness-turn-contract.v2",
  "version": "2026-03-08.r1",
  "turn": {
    "states": [
      "in_progress",
      "completed",
      "interrupted",
      "failed"
    ],
    "terminalStates": [
      "completed",
      "interrupted",
      "failed"
    ],
    "terminalEvent": "turn/completed",
    "transitions": [
      { "from": "in_progress", "to": "completed" },
      { "from": "in_progress", "to": "interrupted" },
      { "from": "in_progress", "to": "failed" }
    ]
  },
  "releaseDecisionStates": [
    "RELEASE_APPROVED",
    "RELEASE_APPROVED_WITH_ASSUMPTIONS",
    "RELEASE_BLOCKED",
    "EXTERNAL_ACTION_REQUIRED",
    "HARNESS_FAILURE"
  ],
  "taskOutcomeBridge": {
    "allowedByTurnState": {
      "completed": [
        "COMPLETED",
        "PARTIAL"
      ],
      "interrupted": [
        "BLOCKED",
        "NEEDS_INPUT"
      ],
      "failed": [
        "FAILED_VALIDATION",
        "BLOCKED",
        "NEEDS_INPUT"
      ]
    }
  },
  "runDecisionBridge": {
    "allowedTerminalStates": [
      "RELEASE_APPROVED",
      "RELEASE_APPROVED_WITH_ASSUMPTIONS",
      "RELEASE_BLOCKED",
      "EXTERNAL_ACTION_REQUIRED",
      "HARNESS_FAILURE"
    ],
    "completedTaskOutcomeDoesNotImplyReleaseApproved": true,
    "governancePromotionRequiresEvalOrProtectedValidation": true
  }
}
