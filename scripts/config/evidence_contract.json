{
  "schema": "evidence-contract.v2",
  "version": "2026-04-12.r2",
  "sourceDoc": "docs/EVIDENCE_CONTRACT.md",
  "evidenceClasses": {
    "implementation": [
      "changed_file_refs",
      "created_artifacts"
    ],
    "verification": [
      "test_commands",
      "lint_or_check_commands",
      "manual_review_steps"
    ],
    "runtime": [
      "api_responses",
      "protocol_lifecycle_results",
      "terminal_status_or_log_summaries",
      "stage_timeline",
      "flow_trace"
    ],
    "documentation": [
      "docs/CURRENT_ARCHITECTURE.md",
      "docs/ARCHITECTURE_CHANGELOG.md",
      "traceable_sync_note"
    ],
    "risk": [
      "skipped_checks",
      "failed_checks",
      "residual_risk_statements"
    ]
  },
  "minimumEvidenceByChangeType": {
    "docs_only_policy_change": [
      "manual_consistency_review",
      "updated_policy_file_refs",
      "architecture_spec_sync"
    ],
    "server_or_scripts_change": [
      "node scripts/app_server_smoke_test.js"
    ],
    "eval_or_workflow_policy_change": [
      "node scripts/eval_replay_api_smoke_test.js",
      "dedicated_automated_tests"
    ],
    "core_system_change": [
      "node scripts/system_coherence_review_test.js"
    ],
    "web_change": [
      "launch_ui",
      "GET /api/runtime = 200"
    ],
    "skill_assignment_or_package_change": [
      "node scripts/skill_portfolio_audit.js",
      "node scripts/repo_local_skill_catalog_test.js"
    ],
    "read_only_harness_artifact_mcp_change": [
      "node tools/harness-artifact-mcp-server/tests/smoke_test.js"
    ],
    "new_logic_over_delivery": [
      "dedicated_automated_tests"
    ]
  },
  "requiredTurnArtifacts": [
    "requirement_contract.json",
    "requirement_validation.json",
    "dispatch_plan.json",
    "evidence_manifest.json",
    "stage_timeline.json",
    "flow_trace_summary.json",
    "review_load_breakdown.json",
    "iteration_decision.json",
    "release_decision.json",
    "adoption_readiness_eval.json"
  ],
  "reviewerProofSurface": {
    "serverBoundaryWork": {
      "acceptanceChecks": {
        "ac-1": "Reviewer can refresh the baseline comparison and reopen the reviewer packet from explicit package-visible commands without discovering hidden helper paths.",
        "ac-2": "Tester can run one dedicated verification command that covers the extracted server-boundary split tests plus the reviewer/export proof surfaces."
      },
      "reviewerRefreshCommand": "npm run reviewer:baseline-comparison",
      "reviewerProofCommand": "npm run reviewer:server-boundary-proof",
      "testerProofCommand": "npm run test:server-boundary-proof",
      "reviewerArtifacts": [
        "output/governance_public/reviewer_start_here.json",
        "output/server_boundary_refactor_reviewer_evidence.md",
        "output/playwright/reviewer-overview-2026-04-13.png"
      ],
      "testerArtifacts": [
        "output/server_boundary_refactor_tester_evidence.md",
        "output/submission_artifacts.json"
      ]
    }
  }
}
